rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allows anyone to read the campaign settings
    match /settings/campaign {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Orders rules
    match /orders/{orderId} {
      // Allow anyone to create an order
      allow create: if true;
      
      // Allow anyone to read orders so the grid can calculate taken numbers
      // NOTE: In a real production app, you might want to only expose the "numbers" and "status" fields for privacy.
      allow read: if true;
      
      // Allow update for status change (automatic pix approval or admin review)
      // We allow anyone to update IF they are changing status to approved (for automatic pix)
      // but strictly we should probably only allow if authorized OR if we trust the client logic (which we kind of have to here since it's client-side Pix detection)
      allow update: if true;
      
      allow delete: if request.auth != null;
    }
  }
}
